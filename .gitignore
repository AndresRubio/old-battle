# Dependencies
node_modules

# Build output
dist
dist-ssr
*.local

# Vite / dev cache
.vite

# TypeScript incremental build info
*.tsbuildinfo

# Test coverage
coverage

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment / secrets — never commit these
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Claude Code local settings
.claude/settings.local.json

# --- Capacitor / Android (generated by `npx cap add android`) ---
# Gradle
android/.gradle
android/build
android/app/build
android/captures
android/local.properties

# Signing keys — NEVER commit
*.keystore
*.jks
android/key.properties

# Capacitor copies the web build into the native project
android/app/src/main/assets/public
android/app/src/main/res/raw

# iOS (if ever added)
ios/App/Pods
ios/App/output
